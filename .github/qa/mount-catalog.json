{
  "$schema": "caas-mount-catalog/v1",
  "description": "Verified configs/card-data that mount each CaaS feature on the local index.html harness. Used to deterministically set up a scenario (Phase 1) before diffing old-vs-new.",
  "harness": {
    "page": "index.html",
    "serve": "localhost (npm start / python http.server); localhost uses local mock-json collection"
  },
  "lever": {
    "cardStyle": "collection.cardStyle (aliases 1:2->one-half, 3:4->three-fourths); per-card via card.styles.typeOverride",
    "cardData": "cards come from the collection endpoint JSON; patch a card to trigger data-driven features"
  },
  "entries": [

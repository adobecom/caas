      "feature": "card-style",
      "variant": "one-half",
      "config": {
        "collection": {
          "cardStyle": "1:2"
        }
      },
      "cardPatch": null,
      "expect": {
        "selector": ".consonant-Card.one-half",
        "min": 1
      },
      "verified": true,
      "notes": "global collection.cardStyle; alias"
    },
